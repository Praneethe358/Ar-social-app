# Local development only — NOT used by Render (set env vars in Render dashboard)
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ar_social_network

# DO NOT set VITE_API_URL here — it gets baked into the Vite build bundle!
# In production, api.js auto-detects the origin (window.location.origin/api).
# Only set VITE_API_URL locally if you need to override, e.g.:
# VITE_API_URL=http://localhost:5000/api
