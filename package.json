{
  "name": "ar-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "nodemon --watch backend backend/server.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "start:server": "node backend/server.js"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "mongoose": "^8.12.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "vite": "^5.4.21"
  }
}
